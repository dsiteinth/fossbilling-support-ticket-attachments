{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ ticket.subject }}{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ 'build/css/markdown.css' | asset_url }}">
    {{ mf.wysiwyg('.editor-textarea') }}
    <style>
        /* ── Progress Bar ── */
        .sta-progress-wrap { margin-top:10px; max-width: 100%; display: none; }
        .sta-progress-label { display:flex; justify-content:space-between; font-size:.75rem; color:#6b7280; margin-bottom:.3rem; }
        .sta-progress-track { height:6px; background:#e5e7eb; border-radius:99px; overflow:hidden; }
        .sta-progress-bar { height:100%; background:#4f8ef7; border-radius:99px; transition:width .2s linear; }

        /* ── Toasts ── */
        .sta-toasts { position:fixed; bottom:1.25rem; right:1.25rem; display:flex; flex-direction:column; gap:.5rem; z-index:9999; pointer-events:none; }
        .sta-toast {
            display:flex; align-items:center; gap:.6rem; padding:.65rem 1rem; border-radius:10px;
            font-size:.82rem; font-weight:500; color:#fff; box-shadow:0 4px 20px rgba(0,0,0,.18);
            pointer-events:all; animation:sta-toast-in .25s ease; max-width:320px;
        }
        @keyframes sta-toast-in { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
        .sta-toast-success { background:#22c55e; }
        .sta-toast-error   { background:#ef4444; }
        .sta-toast-warn    { background:#f59e0b; color:#111; }

        /* ── Limit image sizes in ticket view ── */
        .markdown-body img, .editor-textarea img, .ck-content img {
            max-width: 100%;
            max-height: 350px;
            object-fit: contain;
            border-radius: 6px;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .markdown-body img:hover {
            transform: scale(1.02);
        }
    </style>
{% endblock %}

{% block body_class %}support-ticket{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ 'support'|url }}">{{ 'Support Tickets'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ ticket.subject }}</li>
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-md-12">
            <div class="card mb-3">
                <div class="card-header py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-2">{{ 'Ticket'|trans }} #{{ ticket.id }}</h5>
                        </div>
                        <div class="">
                            <div class="d-flex gap-2">
                                {% if (ticket.status != 'closed') or (ticket.helpdesk.can_reopen) %}
                                    <button class="btn btn-info btn-sm" id="reply-to-btn">{{ 'Reply'|trans }}</button>
                                {% endif %}
                                {% if ticket.status != 'closed' %}
                                    <button class="btn btn-secondary btn-sm" type="button" id="ticket-close">{{ 'Close Ticket'|trans }}</button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <table class="table table-hover table-sm">
                        <tbody>
                        <tr>
                            <td>{{ 'Help Desk'|trans }}</td>
                            <td>{{ ticket.helpdesk.name }}</td>
                        </tr>

                        <tr>
                            <td>{{ 'Status'|trans }}</td>
                            <td>
                                {{ mf.status_badge(ticket.status, 'ticket') }}
                            </td>
                        </tr>

                        <tr>
                            <td>{{ 'Time Opened'|trans }}</td>
                            <td>{{ ticket.created_at|format_date }}</td>
                        </tr>

                        {% if ticket.rel_type == 'order' and ticket.rel_id %}
                            <tr>
                                <td>{{ 'Related To'|trans }}</td>
                                <td>
                                    <a href='{{ "order/service/manage/#{ticket.rel_id}"|url }}'>{{ 'Service #'|trans }} {{ ticket.rel_id }}</a>
                                </td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="d-flex flex-column gap-3">
            {% for i, message in ticket.messages %}
                <div class="row">
                    <div class="col-md-12">
                        <div class="card {% if message.author.role == 'admin' %}border-primary{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    {{ mf.avatar(message.author.email, 40, 'db-avatar img-thumbnail d-none d-md-block') }}
                                    <div class="d-flex flex-column">
                                        <span class="text-muted">
                                            {{ message.author.name }}
                                        </span>
                                        {% if message.author.role == 'admin' %}
                                            <span class="badge text-bg-primary">
                                                    {{ 'Operator'|trans }}
                                                </span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">
                                                    {{ 'You'|trans }}
                                                </span>
                                        {% endif %}
                                    </div>
                                    <span class="text-muted fs-7">on {{ message.created_at|format_date }}</span>
                                </div>
                                {% if (ticket.status != 'closed') or (ticket.helpdesk.can_reopen) %}
                                    <div class="d-flex gap-3 align-items-center">
                                        <span class="text-muted fs-7">#{{ message.id }}</span>
                                        <button class="btn btn-outline-secondary btn-quote-reply"
                                                message-quote="{{ mf.markdown_quote(message.content) }}"
                                                data-bs-toggle="tooltip" data-bs-title="{{ 'Quote Reply'|trans }}">
                                            <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg"
                                                 viewBox="0 0 24 24">
                                                <path d="M11 18V10H9.12L11.12 6H5.38L3 10.76V18M9 16H5V11.24L6.62 8H7.88L5.88 12H9M21 18V10H19.12L21.12 6H15.38L13 10.76V18M19 16H15V11.24L16.62 8H17.88L15.88 12H19Z"/>
                                            </svg>
                                        </button>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-12">
                                        <article class="markdown-body bg-transparent text-reset" id="message-{{ message.id }}">
                                            {{ (message.content ?? '')|markdown_to_html }}
                                        </article>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div>
            <div class="row">
                <div class="col-md-12">
                    {% if ticket.status == 'closed' and not ticket.helpdesk.can_reopen %}
                        <div class="mt-3 alert alert-secondary text-center">{{ 'Ticket was closed and cannot be reopened.'|trans }}</div>
                    {% else %}
                        {% if ticket.status == 'closed' %}
                            <div class="mt-3 alert alert-secondary text-center">{{ 'This ticket was closed, but you can still reopen it by replying.'|trans }}</div>
                        {% endif %}
                        <div class="card mt-3" id="reply-to">
                            <div class="card-body">
                                <form id="ticket-reply-form">
                                    <input type="hidden" name="id" value="{{ ticket.id }}">
                                    <textarea name="content" cols="5" rows="10" class="editor-textarea form-control" required="required"
                                              id="ticket-reply-text"></textarea>
                                    <button class="mt-2 btn btn-primary" type="submit" id="post-reply-btn"
                                            value="{{ 'Post'|trans }}"
                                            onclick="">{{ 'Post'|trans }}</button>
                                </form>                                    {# ฤฤ INJECTED: Inline Upload Button ฤฤ #}
                                    <div class="mt-3">
                                        <button type="button" id="sta-inline-btn" title="Upload and insert an image or file into your message" style="background:#fff; border:1px solid #ced4da; padding:6px 14px; border-radius:6px; cursor:pointer; font-size:14px; font-weight:500; display:inline-flex; align-items:center; gap:8px; color:#495057; box-shadow:0 1px 2px rgba(0,0,0,0.05); transition:all 0.15s ease;">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline>
                                            </svg>
                                            {{ 'Insert Image / File'|trans }}
                                        </button>
                                        <input type="file" id="sta-inline-input" style="display:none;" multiple accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt,.zip">
                                        
                                        <div id="sta-progress-wrap" class="sta-progress-wrap" style="display:none; margin-top:10px; max-width:100%;">
                                            <div class="sta-progress-label" style="display:flex; justify-content:space-between; font-size:.75rem; color:#6b7280; margin-bottom:.3rem;">
                                                <span id="sta-progress-filename"></span>
                                                <span id="sta-progress-pct">0%</span>
                                            </div>
                                            <div class="sta-progress-track" style="height:6px; background:#e5e7eb; border-radius:99px; overflow:hidden;">
                                                <div id="sta-progress-bar" class="sta-progress-bar" style="height:100%; background:#4f8ef7; border-radius:99px; transition:width .2s linear; width:0%"></div>
                                            </div>
                                        </div>
                                    </div>
</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block js %}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ticketReplyForm = document.getElementById('ticket-reply-form');
            const closeTicketBtn = document.getElementById('ticket-close');
            const postReplyBtn = document.getElementById('post-reply-btn');
            const replyToMessageBtn = document.querySelectorAll('.btn-quote-reply');
            const ticketReplyTextArea = document.getElementById('ticket-reply-text');

            ticketReplyForm?.addEventListener('submit', (e) => {
                e.preventDefault();
                API.client.post('support/ticket_reply', Tools.serializeFormDataToObject(new FormData(ticketReplyForm)),
                    () => {
                        flashMessage({
                            message: 'Posted reply',
                            reload: true
                        });
                    },
                    (res) => FOSSBilling.message(`${res.message} (${res.code})`, 'error')
                )
            });

            closeTicketBtn?.addEventListener('click', (e) => {
                e.preventDefault();
                toggleLoader();
                API.client.post('support/ticket_close', Tools.serializeFormDataToObject(new FormData(ticketReplyForm)),
                    () => {
                        flashMessage({
                            message: 'Closed ticket #{{ ticket.id }}',
                            reload: true
                        });
                    },
                    (res) => FOSSBilling.message(`${res.message} (${res.code})`, 'error')
                )
            });

            postReplyBtn?.addEventListener('click', () => {
                if (document.getElementById('ticket-reply-text').value.length > 0) {
                    toggleLoader();
                }
            });

            replyToMessageBtn.forEach((reply) => {
                reply.addEventListener('click', (e) => {
                    e.preventDefault();
                    let quote = e.currentTarget.getAttribute('message-quote');
                    quote = quote.replace(/^\s*$(?:\r\n?|\n)/gm, '');
                    if (ticketReplyTextArea.editor) {
                        ticketReplyTextArea.editor.setData(quote);
                        ticketReplyTextArea.editor.editing.view.focus();
                    } else {
                        ticketReplyTextArea.textContent = quote;
                        ticketReplyTextArea.focus();
                    }
                });
            })

            document.getElementById('reply-to-btn')?.addEventListener('click', () => {
                if (ticketReplyTextArea.editor) {
                    ticketReplyTextArea.editor.editing.view.focus();
                } else {
                    ticketReplyTextArea.focus();
                }
            });

            const toggleLoader = () => {
                let loader = document.querySelector('.wait');
                if (!loader) {
                    return;
                }
                if (loader.style.display === 'none') {
                    loader.style.display = 'block';
                } else {
                    loader.style.display = 'none';
                }
            }

            // ==========================================
            // Support Ticket Attachments Inline Logic
            // ==========================================
            const TICKET_ID = {{ ticket.id | default(0) | json_encode }};
            const API_BASE = '/api/client/supportticketattachments';
            const btn = document.getElementById('sta-inline-btn');
            const input = document.getElementById('sta-inline-input');
            const progWrap = document.getElementById('sta-progress-wrap');
            const progBar = document.getElementById('sta-progress-bar');
            const progPct = document.getElementById('sta-progress-pct');
            const progName = document.getElementById('sta-progress-filename');

            if (!btn || !input) return;

            // Toasts container setup
            const toastCont = document.createElement('div');
            toastCont.className = 'sta-toasts';
            document.body.appendChild(toastCont);

            function showToast(msg, type = 'success') {
                const el = document.createElement('div');
                el.className = `sta-toast sta-toast-${type}`;
                el.innerHTML = `<span>${msg}</span>`;
                toastCont.appendChild(el);
                setTimeout(() => {
                    el.style.opacity = '0';
                    el.style.transition = 'opacity .3s';
                    setTimeout(() => el.remove(), 300);
                }, 4000);
            }

            function getCsrfToken() {
                if (typeof FOSSBilling !== 'undefined' && FOSSBilling.CSRFToken) return FOSSBilling.CSRFToken;
                const value = `; ${document.cookie}`;
                let parts = value.split(`; CSRFToken=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
                parts = value.split(`; csrf_token=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
                return '';
            }

            function setProgress(pct, name) {
                if (pct === null) {
                    progWrap.style.display = 'none';
                } else {
                    progWrap.style.display = 'block';
                    progBar.style.width = pct + '%';
                    progPct.textContent = pct + '%';
                    progName.textContent = name || '';
                }
            }

            btn.addEventListener('click', () => input.click());
            btn.addEventListener('mouseenter', () => btn.style.borderColor = '#4f8ef7');
            btn.addEventListener('mouseleave', () => btn.style.borderColor = '#ced4da');

            const ALLOWED_EXT = ['jpg','jpeg','png','gif','pdf','doc','docx','txt','zip'];
            const MAX_BYTES = 5 * 1024 * 1024;

            input.addEventListener('change', () => {
                if (!input.files?.length) return;
                Array.from(input.files).forEach(file => {
                    const ext = file.name.split('.').pop().toLowerCase();
                    if (!ALLOWED_EXT.includes(ext)) {
                        showToast(`"${file.name}" — file type not allowed.`, 'error');
                        return;
                    }
                    if (file.size > MAX_BYTES) {
                        showToast(`"${file.name}" — file is too large.`, 'error');
                        return;
                    }
                    uploadFile(file);
                });
                input.value = '';
            });

            function uploadFile(file) {
                setProgress(0, file.name);
                const fd = new FormData();
                fd.append('ticket_id', TICKET_ID);
                fd.append('CSRFToken', getCsrfToken());
                fd.append('file', file);

                const xhr = new XMLHttpRequest();
                xhr.open('POST', API_BASE + '/upload', true);
                xhr.setRequestHeader('X-CSRF-Token', getCsrfToken());

                xhr.upload.addEventListener('progress', e => {
                    if (e.lengthComputable) setProgress(Math.round((e.loaded / e.total) * 100), file.name);
                });

                xhr.addEventListener('load', () => {
                    setProgress(null);
                    try {
                        const res = JSON.parse(xhr.responseText);
                        if (res.result) {
                            insertIntoEditor(res.result);
                            showToast('Inserted!', 'success');
                        } else {
                            showToast(res.error?.message || 'Upload failed.', 'error');
                        }
                    } catch {
                        showToast('Upload failed.', 'error');
                    }
                });

                xhr.addEventListener('error', () => {
                    setProgress(null);
                    showToast('Network error.', 'error');
                });

                xhr.withCredentials = true;
                xhr.send(fd);
            }

            function insertIntoEditor(att) {
                const url = window.location.origin + '/supportticketattachments/download/' + att.id;
                const isImage = att.mime_type && att.mime_type.startsWith('image/');
                
                let insertHTML;
                let insertMarkdown;

                if (isImage) {
                    insertHTML = `<a href="${url}" target="_blank" title="Click to view full image"><img src="${url}" alt="${att.original_filename}" style="max-width:100%; max-height:350px; border-radius:6px; margin: 10px 0; border:1px solid #dee2e6;" /></a>`;
                    insertMarkdown = `\n\n[![${att.original_filename}](${url})](${url})\n\n`;
                } else {
                    insertHTML = `<a href="${url}" target="_blank">📎 ${att.original_filename}</a>`;
                    insertMarkdown = `\n\n[📎 ${att.original_filename}](${url})\n\n`;
                }

                const ticketReplyTextArea = document.getElementById('ticket-reply-text');
                
                if (ticketReplyTextArea.editor) {
                    try {
                        const editor = ticketReplyTextArea.editor;
                        editor.model.change(writer => {
                            if (isImage) {
                                try {
                                    const imageElement = writer.createElement('imageBlock', { src: url, linkHref: url });
                                    editor.model.insertContent(imageElement);
                                } catch(e) {
                                    try {
                                        const imageElement = writer.createElement('imageInline', { src: url, linkHref: url });
                                        editor.model.insertContent(imageElement);
                                    } catch(e2) {
                                        // Fallback
                                    }
                                }
                            } else {
                                const text = writer.createText('📎 ' + att.original_filename, { linkHref: url });
                                editor.model.insertContent(text);
                            }
                        });
                        return;
                    } catch (e) {
                        try {
                            ticketReplyTextArea.editor.setData(ticketReplyTextArea.editor.getData() + '<p>' + insertHTML + '</p>');
                            return;
                        } catch(e2) {}
                    }
                }

                if (window.jQuery && jQuery(ticketReplyTextArea).data('summernote')) {
                    jQuery(ticketReplyTextArea).summernote('pasteHTML', insertHTML);
                    return;
                }

                if (window.jQuery && jQuery(ticketReplyTextArea).data('trumbowyg')) {
                    const currentHtml = jQuery(ticketReplyTextArea).trumbowyg('html');
                    jQuery(ticketReplyTextArea).trumbowyg('html', currentHtml + '<p>' + insertHTML + '</p>');
                    return;
                }

                if (typeof SimpleMDE !== 'undefined' && ticketReplyTextArea.simplemde) {
                    const smde = ticketReplyTextArea.simplemde;
                    const pos = smde.codemirror.getCursor();
                    smde.codemirror.setSelection(pos, pos);
                    smde.codemirror.replaceSelection(insertMarkdown);
                    return;
                }

                const startPos = ticketReplyTextArea.selectionStart;
                const endPos = ticketReplyTextArea.selectionEnd;
                ticketReplyTextArea.value = ticketReplyTextArea.value.substring(0, startPos)
                    + insertMarkdown
                    + ticketReplyTextArea.value.substring(endPos, ticketReplyTextArea.value.length);
                
                ticketReplyTextArea.dispatchEvent(new Event('input', { bubbles: true }));
                ticketReplyTextArea.dispatchEvent(new Event('change', { bubbles: true }));
            }

            // Global image click listener
            document.addEventListener('click', function(e) {
                if (e.target.tagName === 'IMG') {
                    const isTicketImage = e.target.closest('article[id^="message-"]');
                    if (isTicketImage) {
                        if (!e.target.closest('a')) {
                            window.open(e.target.src, '_blank');
                        }
                    }
                }
            });
        });
    </script>
{% endblock %}
